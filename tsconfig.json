{
  // Setup ADDITIF : outille TypeScript pour les NOUVEAUX fichiers .ts/.tsx
  // (IntelliSense, alias @, typecheck). Le JS existant n'est JAMAIS vérifié
  // (checkJs: false) ni converti — Vite/esbuild transpile comme avant, tsc ne
  // sert qu'à l'IDE et au check manuel (npx tsc --noEmit).
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": false,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
